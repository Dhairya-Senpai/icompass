# ─────────────────────────────────────────────────────────────────────────────
# icompass Platform — Environment Configuration
# Copy this file to .env.local for local development.
# Never commit .env.local to git.
# For GitHub Pages, set these as repository Secrets / Variables in:
#   Settings → Secrets and variables → Actions
# ─────────────────────────────────────────────────────────────────────────────

# ── Deployment ────────────────────────────────────────────────────────────────
# The base URL path for GitHub Pages.
# If your repo is github.com/username/icompass-platform, set this to /icompass-platform/
# If using a custom domain, set to /
VITE_BASE_URL=/icompass/

# ── App identity ──────────────────────────────────────────────────────────────
VITE_APP_NAME="icompass Platform"
VITE_APP_TAGLINE="Customer Discovery Platform"

# ── AI / Ollama ───────────────────────────────────────────────────────────────
# Base URL for your local (or hosted) Ollama instance.
# For local dev: http://localhost:11434
# For a hosted instance: https://your-ollama-server.example.com
VITE_OLLAMA_BASE_URL=http://localhost:11434

# Default model to use. Must be pulled first: ollama pull llama3.2
VITE_OLLAMA_MODEL=llama3.2

# Request timeout in milliseconds (default 60000 = 60s)
VITE_OLLAMA_TIMEOUT=60000

# ── Feature flags ─────────────────────────────────────────────────────────────
# Set to "true" to enable a feature, "false" to hide it from the UI
VITE_FEATURE_AI_HYPOTHESIS=true
VITE_FEATURE_AI_ANALYSIS=true
VITE_FEATURE_EXPORT=true

# ── Interview settings ────────────────────────────────────────────────────────
# Default interview goal per team
VITE_DEFAULT_INTERVIEW_GOAL=15

# ── Persistence ───────────────────────────────────────────────────────────────
# localStorage key prefix (change to namespace multiple deployments)
VITE_STORAGE_KEY=icompass_v1
